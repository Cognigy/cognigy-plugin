{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "Order summary",
      "weight": "Bolder",
      "size": "Medium",
      "wrap": true
    },
    {
      "type": "Container",
      "separator": true,
      "items": [
        {
          "type": "ColumnSet",
          "columns": [
            { "type": "Column", "width": "stretch", "items": [{ "type": "TextBlock", "text": "Sample item", "wrap": true }] },
            { "type": "Column", "width": "auto", "items": [{ "type": "TextBlock", "text": "1x", "horizontalAlignment": "Right" }] },
            { "type": "Column", "width": "auto", "items": [{ "type": "TextBlock", "text": "$0.00", "horizontalAlignment": "Right" }] }
          ]
        }
      ]
    },
    {
      "type": "ColumnSet",
      "separator": true,
      "columns": [
        { "type": "Column", "width": "stretch", "items": [{ "type": "TextBlock", "text": "Total", "weight": "Bolder" }] },
        { "type": "Column", "width": "auto", "items": [{ "type": "TextBlock", "text": "$0.00", "weight": "Bolder", "horizontalAlignment": "Right" }] }
      ]
    }
  ],
  "actions": [
    { "type": "Action.Submit", "title": "Confirm", "style": "positive", "data": { "confirmed": true } },
    { "type": "Action.Submit", "title": "Cancel", "data": { "confirmed": false } }
  ]
}
