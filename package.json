{
  "name": "@cognigy/mcp-server",
  "version": "0.2.0",
  "description": "Model Context Protocol server for Cognigy.AI REST API",
  "main": "dist/index.js",
  "bin": {
    "cognigy-mcp": "dist/index.js"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "QUICK_START.md"
  ],
  "scripts": {
    "build": "npx tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "setup": "bash scripts/setup.sh",
    "test-connection": "bash scripts/test-connection.sh",
    "prepublishOnly": "npm run build",
    "mcpb:pack": "npm run build && npx @anthropic-ai/mcpb pack"
  },
  "keywords": [
    "mcp",
    "cognigy",
    "ai",
    "model-context-protocol",
    "mcp-server",
    "conversational-ai"
  ],
  "author": "Cognigy",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.6.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
