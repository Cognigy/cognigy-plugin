{
  "name": "@cognigy/mcp-server",
  "version": "0.2.6",
  "description": "Model Context Protocol server for Cognigy.AI REST API",
  "main": "dist/index.js",
  "bin": {
    "cognigy-mcp": "dist/index.js"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "QUICK_START.md"
  ],
  "scripts": {
    "build": "npx tsc && cp -r src/resources dist/resources",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "setup": "bash scripts/setup.sh",
    "test-connection": "bash scripts/test-connection.sh",
    "prepublishOnly": "npm run build",
    "mcpb:pack": "npm run build && npx @anthropic-ai/mcpb pack"
  },
  "keywords": [
    "mcp",
    "cognigy",
    "ai",
    "model-context-protocol",
    "mcp-server",
    "conversational-ai"
  ],
  "author": "Cognigy",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "axios": "1.13.6",
    "form-data": "4.0.5",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "20.19.35",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "eslint": "8.57.1",
    "jest": "29.7.0",
    "ts-jest": "29.4.6",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
