{
  "name": "@cognigy/mcp-server",
  "version": "0.2.12",
  "description": "Model Context Protocol server for Cognigy.AI REST API",
  "main": "dist/index.js",
  "bin": {
    "cognigy-mcp": "dist/index.js"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && npx tsc && cp -r src/resources dist/resources",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:local": "bash scripts/run-local-mcp.sh",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:init-local": "bash scripts/test-local-init.sh",
    "prettier:check": "prettier --check",
    "prettier:write": "prettier --write",
    "lint": "eslint src --ext .ts",
    "setup": "bash scripts/setup.sh",
    "test-connection": "bash scripts/test-connection.sh",
    "prepublishOnly": "npm run build",
    "mcpb:pack": "npm run build && npx @anthropic-ai/mcpb pack"
  },
  "keywords": [
    "mcp",
    "cognigy",
    "ai",
    "model-context-protocol",
    "mcp-server",
    "conversational-ai"
  ],
  "author": "Cognigy",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "axios": "1.13.6",
    "form-data": "4.0.5",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "20.19.35",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "eslint": "8.57.1",
    "jest": "29.7.0",
    "prettier": "3.6.2",
    "ts-jest": "29.4.6",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
