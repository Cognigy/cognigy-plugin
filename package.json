{
  "name": "@cognigy/plugin-engine",
  "version": "1.2.0",
  "description": "MCP server engine for the NiCE Cognigy Plugin (Claude Code, Codex, and more)",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "cognigy-setup": "dist/setup.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cognigy/cognigy-plugin"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && npx tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "prettier:check": "prettier --check",
    "prettier:write": "prettier --write",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "cognigy",
    "ai",
    "model-context-protocol",
    "mcp-server",
    "conversational-ai",
    "claude-code-plugin"
  ],
  "author": "Cognigy",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "axios": "1.13.6",
    "form-data": "4.0.5",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/jest": "29.5.14",
    "@types/node": "20.19.35",
    "@typescript-eslint/eslint-plugin": "6.21.0",
    "@typescript-eslint/parser": "6.21.0",
    "eslint": "8.57.1",
    "husky": "^9.1.7",
    "jest": "29.7.0",
    "prettier": "3.6.2",
    "semantic-release": "^25.0.3",
    "ts-jest": "29.4.6",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
